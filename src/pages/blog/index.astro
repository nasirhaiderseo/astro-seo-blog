---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedPost from '../../components/FeaturedPost.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog"
  description="Off-page SEO guides, guest posting strategies, and link building insights from Web Grouth."
>
  {
    featured ? (
      <FeaturedPost post={featured} />
    ) : (
      <section class="border-b border-slate-200 bg-soft py-20">
        <div class="container-site">
          <h1 class="text-3xl font-semibold text-charcoal">Blog</h1>
          <p class="mt-4 text-slate-600">No articles published yet.</p>
        </div>
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="py-16 lg:py-20">
        <div class="container-site">
          <div class="flex items-end justify-between border-b border-slate-200 pb-6">
            <h2 class="text-lg font-medium text-charcoal">All articles</h2>
            <p class="text-sm text-slate-500">{rest.length} posts</p>
          </div>

          <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {rest.map((post) => <BlogCard post={post} />)}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
