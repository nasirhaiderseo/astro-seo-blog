---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedPost from '../../components/FeaturedPost.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog"
  description="Off-page SEO guides, guest posting strategies, and link building playbooks from the Web Grouth team."
>
  {
    featured ? (
      <FeaturedPost post={featured} />
    ) : (
      <section class="border-b border-white/5 bg-surface-950 py-20">
        <div class="container-site text-center">
          <h1 class="text-4xl font-bold text-white">Blog</h1>
          <p class="mt-4 text-slate-400">No posts yet. Check back soon!</p>
        </div>
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="py-20">
        <div class="container-site">
          <div class="reveal mb-10 flex items-end justify-between">
            <div>
              <span class="section-label">All Articles</span>
              <h2 class="mt-3 text-2xl font-bold text-white">More Insights</h2>
            </div>
            <p class="hidden text-sm text-slate-500 sm:block">{rest.length} articles</p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {rest.map((post, i) => (
              <div class="reveal" style={`animation-delay: ${i * 80}ms`}>
                <BlogCard post={post} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="border-t border-white/5 bg-surface-950 py-16">
    <div class="container-site">
      <div
        class="reveal flex flex-col items-center rounded-2xl border border-brand-500/20 bg-brand-950/20 p-10 text-center"
      >
        <h2 class="text-2xl font-bold text-white">Want links that actually rank?</h2>
        <p class="mt-3 max-w-lg text-slate-400">
          Stop reading and start building. Our guest posting packages start at $299/placement.
        </p>
        <a href="/contact" class="btn-primary mt-6"> Get a Custom Quote </a>
      </div>
    </div>
  </section>
</BaseLayout>
