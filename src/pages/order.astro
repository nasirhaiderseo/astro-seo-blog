---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Place Your Order — Web Grouth"
  description="Order premium guest posts and authority backlinks. Fill in your campaign details and budget."
>
  <!-- یہاں ہیڈنگ اور تحریر کو انتہائی مختصر اور کمپیکٹ کر دیا گیا ہے تاکہ موبائل پر کم جگہ لے -->
  <PageHero
    label="Order"
    title="Order Guest Posts"
    description="Submit your details below. We will review and reply in 10 minutes."
  />

  <section class="py-12 lg:py-16 reveal">
    <div class="container-site max-w-3xl">
      <form id="order-form" class="card rounded-3xl p-8 lg:p-10 shadow-lg shadow-blue-50/50" action="#" method="POST">
        <h3 class="text-xl font-bold text-slate-950">Campaign Details</h3>
        <p class="mt-1 text-xs text-slate-400">Please provide your details below. We will review and contact you within 10 minutes.</p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <!-- نام -->
          <div>
            <label for="order-name" class="mb-1.5 block text-xs font-semibold text-slate-700">Your Full Name *</label>
            <input
              type="text"
              id="order-name"
              name="name"
              required
              placeholder="Your Name"
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            />
          </div>
          <!-- ای میل -->
          <div>
            <label for="order-email" class="mb-1.5 block text-xs font-semibold text-slate-700">Email Address *</label>
            <input
              type="email"
              id="order-email"
              name="email"
              required
              placeholder="name@email.com"
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            />
          </div>
        </div>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <!-- ویب سائٹ لنک -->
          <div>
            <label for="target-site" class="mb-1.5 block text-xs font-semibold text-slate-700">Your Website URL *</label>
            <input
              type="text"
              id="target-site"
              name="target_site"
              required
              placeholder="https://yourwebsite.com"
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            />
          </div>
          <!-- بجٹ -->
          <div>
            <label for="order-budget" class="mb-1.5 block text-xs font-semibold text-slate-700">Your Campaign Budget ($) *</label>
            <input
              type="text"
              id="order-budget"
              name="budget"
              required
              placeholder="Enter your budget (e.g. $150, $500)"
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            />
          </div>
        </div>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <!-- اینکر ٹیکسٹ -->
          <div>
            <label for="anchor-text" class="mb-1.5 block text-xs font-semibold text-slate-700">Anchor Text & Backlink Target *</label>
            <input
              type="text"
              id="anchor-text"
              name="anchor_text"
              required
              placeholder="Example: 'SEO agency' linking to 'yoursite.com/seo'"
              class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            />
          </div>
          <!-- ڈومین ریکیورمنٹ -->
          <div>
            <label for="min-requirement" class="mb-1.5 block text-xs font-semibold text-slate-700">Minimum Site DR Required *</label>
            <select
              id="min-requirement"
              name="min_requirement"
              required
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
            >
              <option value="">Select authority level</option>
              <option value="da-30">Basic (DR 30+ blogs)</option>
              <option value="da-50">Standard (DR 50+ blogs)</option>
              <option value="da-70">High-Authority (DR 70+ blogs)</option>
            </select>
          </div>
        </div>

        <!-- آرٹیکل آپشن -->
        <div class="mt-5">
          <label class="mb-2 block text-xs font-semibold text-slate-700">Do you have an article ready? *</label>
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="flex items-center gap-3 card p-4 cursor-pointer hover:border-blue-600 transition-colors rounded-2xl">
              <input type="radio" name="article_option" value="write" checked class="h-4 w-4 text-blue-600 focus:ring-blue-500" />
              <div>
                <p class="text-xs font-bold text-slate-950">Write it for me</p>
                <p class="text-[10px] text-slate-400">Our team writes high-quality SEO content.</p>
              </div>
            </label>
            <label class="flex items-center gap-3 card p-4 cursor-pointer hover:border-blue-600 transition-colors rounded-2xl">
              <input type="radio" name="article_option" value="provide" class="h-4 w-4 text-blue-600 focus:ring-blue-500" />
              <div>
                <p class="text-xs font-bold text-slate-950">I will provide my own article</p>
                <p class="text-[10px] text-slate-400">Must be 100% original and 800+ words.</p>
              </div>
            </label>
          </div>
        </div>

        <!-- اسپیشل ہدایات -->
        <div class="mt-5">
          <label for="order-instructions" class="mb-1.5 block text-xs font-semibold text-slate-700">Special Instructions / Target Niche</label>
          <textarea
                id="order-instructions"
                name="message"
                rows="4"
                placeholder="List your target niche (e.g., Tech, Finance) or paste any specific guidelines here..."
                class="w-full resize-y rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
              ></textarea>
        </div>

        <button type="submit" class="btn-primary mt-6 w-full sm:w-auto py-3 px-8 shadow-lg shadow-blue-200">
          Submit Your Order
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* اسکرول ریویل کی بنیادی حالت */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  /* جب اسکرول کر کے ایلیمنٹ ظاہر ہو */
  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // فارم سبمیشن اسکرپٹ (آرڈر سبمٹ کرنے پر پاپ اب)
  const form = document.getElementById('order-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const original = btn.textContent;
    btn.textContent = '✓ Order Received!';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = original;
      btn.disabled = false;
      alert("Order Submitted Successfully! We will contact you on WhatsApp / Email within 10 minutes with your custom invoice.");
      form.reset();
    }, 2000);
  });

  // اسکرول ریویل لاجک
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('show');
      }
    });
  }, {
    threshold: 0.15
  });

  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });
</script>
