---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPosts = posts.slice(0, 3);

const heroWords = ["SEO Success", "Guest Posts", "Link Power", "Real Authority"];

const publishers = [
  { name: "Forbes.com", dr: 95 },
  { name: "TechCrunch.com", dr: 94 },
  { name: "BusinessInsider.com", dr: 92 },
  { name: "Entrepreneur.com", dr: 90 },
  { name: "NYTimes.com", dr: 96 },
  { name: "Wired.com", dr: 91 },
  { name: "Inc.com", dr: 89 },
  { name: "Mashable.com", dr: 88 },
];

const testimonials = [
  { name: "Sarah Malik", role: "SEO Director, Brightlane Digital", text: "The DR and traffic numbers were exactly as promised. First agency we've used where the metrics actually held up after delivery.", rating: 5, big: true },
  { name: "David Miller", role: "Founder, SaaSify", text: "Our organic traffic moved within the first month. Communication was clear the entire way through.", rating: 5 },
  { name: "Elena Rostova", role: "Marketing Head, Velorum", text: "Fast turnaround and the support team actually answers questions instead of forwarding to a bot.", rating: 5 },
  { name: "James Anderson", role: "Growth Lead, Northpeak", text: "Switched from a different vendor after getting burned by PBNs. This was a completely different experience — real sites, real editors.", rating: 5, big: true },
  { name: "Aisha Khan", role: "Founder, Aisha & Co", text: "Ranking jumped noticeably within two months. Would recommend to any small business owner who's nervous about SEO.", rating: 5 },
  { name: "Liam O'Connor", role: "SEO Specialist", text: "Checked every placement manually. Couldn't find a single footprint issue across 40+ links.", rating: 5 },
  { name: "Carlos Mendez", role: "Agency Partner, Mendez Media", text: "They replaced two underperforming links without hesitation when we flagged them. That kind of accountability is rare.", rating: 5 },
  { name: "Yuki Tanaka", role: "Digital Marketer", text: "The managed outreach package saved our small team dozens of hours every single week.", rating: 5, big: true },
  { name: "Chloe Dupont", role: "Content Head, Solace Brands", text: "Topical authority content plan was genuinely well researched, not generic filler.", rating: 5 },
  { name: "Zayn Ahmed", role: "Founder, CartLoop", text: "Organic impressions are up significantly and the links are still live a year later.", rating: 5 },
  { name: "Sophia Vester", role: "Traffic Lead", text: "Dashboard makes it easy to filter by niche. Saved me from a lot of back-and-forth emails.", rating: 5 },
  { name: "Marcus Aurel", role: "Independent SEO Consultant", text: "Editorial placements added real link equity to client pages I'd struggled to move for months.", rating: 5, big: true },
  { name: "Fatima Al-Sayed", role: "Brand Manager, Lumora", text: "Traffic numbers lined up with what we saw in our own analytics. That trust matters a lot.", rating: 5 },
  { name: "Oliver Schmidt", role: "SaaS Marketer", text: "The strategy call alone was worth it, gave us a roadmap we still reference.", rating: 5 },
  { name: "Nina Ivanova", role: "Webmaster", text: "Outreach was actually manual, not templated blasts. Relevance was excellent.", rating: 5 },
  { name: "Ryan Reynolds", role: "Agency Lead, Northstar SEO", text: "We moved all our link-building subcontracts here for consistency across every client account.", rating: 5, big: true },
  { name: "Amara George", role: "SEO Strategist", text: "Support replies within minutes, even on the smaller starter plan.", rating: 5 },
  { name: "Thomas Wright", role: "Publisher Relations Director", text: "Editorial standards are tight, only real sites with real audiences get listed.", rating: 5 },
];
---

<BaseLayout
  title="Web Grouth — SEO & Link Building Partner"
  description="Web Grouth is a premium SEO and link building agency. Enterprise-grade off-page SEO, guest posting, and authority building."
>
  <!-- ہیرو سیکشن (Hero Section) — دھیمی اینیمیشن کے ساتھ -->
  <section class="relative overflow-hidden bg-white py-20 lg:py-28">
    <div class="container-site relative z-10 text-center animate-fade-in">
      <!-- پِل بیج (فلوٹنگ اینیمیشن کے ساتھ) -->
      <span class="section-label mb-6 inline-flex items-center gap-1.5 animate-float shadow-sm shadow-blue-100">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-600 animate-ping"></span>
        Trusted by 5,000+ Happy Clients Worldwide
      </span>

      <!-- مین ہیڈنگ -->
      <h1 class="mx-auto mt-4 max-w-4xl text-4xl font-extrabold leading-tight tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
        Scale Your Brand With <br/>
        <span
          id="hero-typewriter"
          class="hero-typewriter bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent drop-shadow-sm"
          data-words={JSON.stringify(heroWords)}
        ></span>
      </h1>

      <!-- ڈسکرپشن -->
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-slate-500 sm:text-lg">
        The global marketplace for premium backlinks, guest posts, and SEO authority — built for brands and agencies that demand real, measurable results.
      </p>

      <!-- ایکشن بٹنز (واٹس ایپ اور ای میل کے ساتھ) -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/order" class="btn-primary w-full sm:w-auto animate-pulse-glow">
          <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
          Start a project
        </a>
        <!-- آپ کا اصل واٹس ایپ نمبر لنک کر دیا گیا ہے -->
        <a href="https://wa.me/923327810261?text=Hi%20Web%20Grouth,%20I%20want%20to%20discuss%20an%20SEO%20project." target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto hover:scale-105 active:scale-95">
          <svg class="h-4 w-4 fill-current text-green-500" viewBox="0 0 24 24"><path d="M12.004 2C6.51 2 2.014 6.5 2 12a9.99 9.99 0 0 0 1.457 5.18l-1.39 5.084 5.21-1.368c1.42.775 3.02 1.185 4.717 1.185 5.51 0 10.002-4.5 10.012-10S17.5 2 12.004 2zm5.72 13.047c-.244.688-1.201 1.25-1.649 1.302-.438.051-.85.253-2.785-.515-2.478-.98-4.072-3.5-4.195-3.664-.123-.163-.997-1.327-.997-2.53 0-1.204.628-1.796.852-2.038.223-.242.487-.302.65-.302.162 0 .324.004.466.01.147.007.345-.056.54.417.198.483.682 1.66.743 1.782.06.12.1.263.02.423-.08.16-.12.26-.24.4-.12.14-.253.313-.362.42-.12.118-.246.248-.106.49.14.24.62 1.024 1.332 1.657.915.815 1.685 1.068 1.924 1.188.24.12.378.1.52-.063.14-.163.606-.704.767-.945.162-.24.325-.2.548-.118.223.081 1.416.667 1.66.788.243.12.405.18.466.282.06.1.06.58-.184 1.27z"/></svg>
          WhatsApp Chat
        </a>
      </div>

      <!-- ٹرسٹ چیک مارکس -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-semibold text-slate-400">
        <span class="flex items-center gap-1.5"><span class="text-blue-500 font-bold">✓</span> Permanent Links</span>
        <span class="flex items-center gap-1.5"><span class="text-blue-500 font-bold">✓</span> Real DR Verified</span>
        <span class="flex items-center gap-1.5"><span class="text-blue-500 font-bold">✓</span> Manual Outreach</span>
        <span class="flex items-center gap-1.5"><span class="text-blue-500 font-bold">✓</span> 98% Success Rate</span>
      </div>
    </div>
  </section>

  <!-- پبلشرز لسٹنگ بار (Editorial Logos) — دائیں سے بائیں خود کار حرکت -->
  <section class="border-y border-slate-100 bg-slate-50/50 py-6 overflow-hidden">
    <div class="ticker-mask">
      <div class="ticker-track-rtl">
        {[...publishers, ...publishers].map((p) => (
          <span class="ticker-chip">
            {p.name}
            <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] text-emerald-600 font-semibold">DR {p.dr}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- کاؤنٹرز (Dark Stats Section) — اسکرول پر گنتی والی اینیمیشن -->
  <section class="py-16 reveal">
    <div class="container-site">
      <div class="rounded-3xl bg-slate-950 p-10 shadow-2xl shadow-blue-900/10 border border-slate-900">
        <div class="grid grid-cols-2 gap-y-10 gap-x-4 md:grid-cols-4 md:gap-y-0 text-center counter-group">
          <div class="transition-transform hover:scale-105 duration-300">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">
              <span class="counter-value" data-target="100" data-suffix="K+">0</span>
            </p>
            <p class="mt-1 text-xs font-medium text-slate-400">Links Delivered</p>
          </div>

          <!-- ہیپی کلائنٹس سیکشن -->
          <div class="transition-transform hover:scale-105 duration-300">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">
              <span class="counter-value" data-target="5000" data-suffix="+">0</span>
            </p>
            <p class="mt-1 text-xs font-medium text-slate-400">Happy Clients</p>
          </div>

          <div class="transition-transform hover:scale-105 duration-300">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">
              <span class="counter-value" data-target="98" data-suffix="%">0</span>
            </p>
            <p class="mt-1 text-xs font-medium text-slate-400">Success Rate</p>
          </div>

          <div class="transition-transform hover:scale-105 duration-300">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">
              <span class="counter-value" data-target="50" data-suffix="+">0</span>
            </p>
            <p class="mt-1 text-xs font-medium text-slate-400">Industries Served</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- سروسز اور صلاحیتیں (Services) — اینیمیٹڈ اسکرول ایفیکٹ -->
  <section class="py-16 bg-slate-50/50 border-y border-slate-100 reveal">
    <div class="container-site">
      <div class="text-center">
        <span class="section-label">Core Capabilities</span>
        <h2 class="mt-4 text-3xl font-extrabold text-slate-950">Expert SEO Frameworks</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-500">We offer specialized off-page campaigns to grow organic exposure securely.</p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          [
            {
              title: 'Authority Building',
              desc: 'High-quality guest postings, niche edits, and curated backlinks from real, vetted blogs with clean history.',
            },
            {
              title: 'Content Velocity',
              desc: 'Topic clusters, evergreen guides, and original assets structured perfectly to earn links naturally.',
            },
            {
              title: 'Technical SEO',
              desc: 'Crawl optimization, schema markup audits, and core web vitals fixes so equity distributes evenly.',
            },
          ].map((item) => (
            <div class="card p-8 group hover:shadow-xl transition-all duration-300">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="mt-6 text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-500">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- قیمتوں کا ٹیبل (Pricing Section) — اینیمیٹڈ اسکرول ایفیکٹ -->
  <section class="py-20 bg-white reveal">
    <div class="container-site">
      <div class="text-center">
        <span class="section-label">Pricing Plans</span>
        <h2 class="mt-4 text-3xl font-extrabold text-slate-950">Simple, Transparent Pricing</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-500">No hidden fees. No PBN footprints. Just premium links that move rankings.</p>
      </div>

      <div class="mt-14 grid gap-8 md:grid-cols-3 items-stretch">
        
        <!-- اسٹارٹر پلان -->
        <div class="card p-8 flex flex-col justify-between hover:shadow-lg transition-all duration-300">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Starter</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$20</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 5 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> High-DA Sites</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Permanent Links</li>
            </ul>
          </div>
          <a href="/order" class="btn-secondary w-full text-center mt-8 py-2.5">Get Started</a>
        </div>

        <!-- اسٹینڈرڈ پلان (Most Popular) -->
        <div class="card p-8 border-blue-200 shadow-md relative flex flex-col justify-between hover:shadow-xl transition-all duration-300 scale-102">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue-600 px-3.5 py-1 text-[9px] font-bold uppercase tracking-wider text-white shadow-sm animate-pulse">⭐ Most Popular</span>
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-blue-600 mt-2">Standard</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$70</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 15 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Managed Outreach</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Article Writing Incl.</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 24/7 Dedicated Support</li>
            </ul>
          </div>
          <a href="/order" class="btn-primary w-full text-center mt-8 py-2.5 shadow-lg shadow-blue-200">Buy Standard</a>
        </div>

        <!-- انٹرپرائز پلان -->
        <div class="card p-8 flex flex-col justify-between hover:shadow-lg transition-all duration-300">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Enterprise</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$200</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 30-45 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Editorial Injections</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Dedicated Strategy</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Advanced Competitor Analysis</li>
            </ul>
          </div>
          <a href="/order" class="btn-secondary w-full text-center mt-8 py-2.5">Contact Us</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ٹیسٹیمونیلز سیکشن — دو قطاریں، خود کار حرکت (بائیں/دائیں) -->
  <section class="py-20 bg-slate-50/30 border-t border-slate-100 reveal overflow-hidden">
    <div class="container-site">
      <div class="text-center">
        <span class="section-label">Client Reviews</span>
        <h2 class="mt-4 text-3xl font-extrabold text-slate-950">What Our Clients Say</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-500">Real feedback from agencies and brands who grew with Web Grouth.</p>
      </div>
    </div>

    <div class="mt-12 space-y-6">
      <!-- قطار اول: بائیں سے دائیں -->
      <div class="testi-mask">
        <div class="testi-track testi-track-ltr">
          {[...testimonials, ...testimonials].map((t) => (
            <div class={`testi-card ${t.big ? 'testi-card-big' : ''}`}>
              <div class="flex items-center gap-3">
                <div class="testi-avatar">{t.name.charAt(0)}</div>
                <div class="min-w-0">
                  <p class="testi-name">{t.name}</p>
                  <p class="testi-role">{t.role}</p>
                </div>
              </div>
              <div class="testi-stars">
                {Array.from({ length: t.rating }).map(() => (
                  <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current"><path d="M10 1.5l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1-5.4 3.1 1.3-6L1.3 7.7l6.1-.6L10 1.5z"/></svg>
                ))}
              </div>
              <p class="testi-text">{t.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- قطار دوم: دائیں سے بائیں -->
      <div class="testi-mask">
        <div class="testi-track testi-track-rtl">
          {[...testimonials.slice().reverse(), ...testimonials.slice().reverse()].map((t) => (
            <div class={`testi-card ${t.big ? 'testi-card-big' : ''}`}>
              <div class="flex items-center gap-3">
                <div class="testi-avatar">{t.name.charAt(0)}</div>
                <div class="min-w-0">
                  <p class="testi-name">{t.name}</p>
                  <p class="testi-role">{t.role}</p>
                </div>
              </div>
              <div class="testi-stars">
                {Array.from({ length: t.rating }).map(() => (
                  <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current"><path d="M10 1.5l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1-5.4 3.1 1.3-6L1.3 7.7l6.1-.6L10 1.5z"/></svg>
                ))}
              </div>
              <p class="testi-text">{t.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- کنورژن بینر (Footer CTA Banner) — اینیمیٹڈ اسکرول ایفیکٹ -->
  <section class="border-t border-slate-100 bg-white py-16 reveal">
    <div class="container-site flex flex-col items-start justify-between gap-6 rounded-3xl bg-slate-50 border border-slate-100 p-10 sm:flex-row sm:items-center hover:shadow-xl transition-shadow duration-300">
      <div>
        <h2 class="text-xl font-bold text-slate-950">Discuss your SEO roadmap</h2>
        <p class="mt-2 text-sm text-slate-500">A straightforward conversation. No pitch decks required. Contact us at hello@webgrouth.com</p>
      </div>
      <a href="/order" class="btn-primary shrink-0 w-full sm:w-auto">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<!-- مائیکرو اینیمیشنز اور اسکرول ایفیکٹ کی لاجک (CSS + JS) -->
<style>
  /* ہیرو فیڈ ان اینیمیشن */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  /* پِل بیج فلوٹنگ اینیمیشن */
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  /* بٹن پر چمکتی ہوئی پلس اینیمیشن */
  @keyframes pulseGlow {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.4);
    }
    50% {
      box-shadow: 0 0 15px 4px rgba(37, 99, 235, 0.2);
    }
  }

  .animate-pulse-glow {
    animation: pulseGlow 2s infinite;
  }

  /* اسکرول ریویل (Scroll Reveal) کی بنیادی حالت */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  /* جب اسکرول کر کے ایلیمنٹ ظاہر ہو */
  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== ہیرو ٹائپ رائٹر (الفاظ کا بدلنا) ===== */
  .hero-typewriter {
    display: inline-block;
    min-height: 1.2em;
  }
  .hero-typewriter::after {
    content: '';
    display: inline-block;
    width: 3px;
    height: 0.9em;
    margin-left: 4px;
    background: currentColor;
    -webkit-text-fill-color: #2563eb;
    vertical-align: text-bottom;
    animation: caretBlink 0.85s step-end infinite;
  }
  @keyframes caretBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ===== پبلشرز ٹِکر (دائیں سے بائیں خود کار حرکت) ===== */
  .ticker-mask {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
