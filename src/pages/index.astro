---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// بلاگز لوڈ کرنے کا ضروری سٹرکچر (جسے ہم نے تبدیل نہیں کیا)
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Web Grouth"
  description="Web Grouth is a premium SEO and link building agency. Enterprise-grade off-page SEO, guest posting, and authority building."
>
  <!-- ہیرو سیکشن (Hero Section) -->
  <section class="relative overflow-hidden bg-white py-20 lg:py-28">
    <div class="container-site relative z-10 text-center">
      <!-- پِل بیج (Pill Badge) -->
      <span class="section-label mb-6">
        <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-blue-600 animate-pulse inline-block"></span>
        Trusted by 5,000+ Agencies Worldwide
      </span>

      <!-- مین ہیڈنگ -->
      <h1 class="mx-auto mt-4 max-w-4xl text-4xl font-extrabold leading-tight tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
        Scale Your Brand With <br/>
        <span class="bg-gradient-to-r from-blue-600 to-blue-500 bg-clip-text text-transparent">SEO Success</span>
      </h1>

      <!-- سب ٹیکسٹ / ڈسکرپشن -->
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-slate-500 sm:text-lg">
        The global marketplace for premium backlinks, guest posts, and SEO authority — built for agencies that demand real, measurable results.
      </p>

      <!-- ایکشن بٹنز (CTAs) -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact" class="btn-primary w-full sm:w-auto">
          <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
          Browse Marketplace
        </a>
        <a href="https://wa.me/yournumber" class="btn-secondary w-full sm:w-auto">
          <svg class="h-4 w-4 fill-current text-green-500" viewBox="0 0 24 24"><path d="M12.004 2C6.51 2 2.014 6.5 2 12a9.99 9.99 0 0 0 1.457 5.18l-1.39 5.084 5.21-1.368c1.42.775 3.02 1.185 4.717 1.185 5.51 0 10.002-4.5 10.012-10S17.5 2 12.004 2zm5.72 13.047c-.244.688-1.201 1.25-1.649 1.302-.438.051-.85.253-2.785-.515-2.478-.98-4.072-3.5-4.195-3.664-.123-.163-.997-1.327-.997-2.53 0-1.204.628-1.796.852-2.038.223-.242.487-.302.65-.302.162 0 .324.004.466.01.147.007.345-.056.54.417.198.483.682 1.66.743 1.782.06.12.1.263.02.423-.08.16-.12.26-.24.4-.12.14-.253.313-.362.42-.12.118-.246.248-.106.49.14.24.62 1.024 1.332 1.657.915.815 1.685 1.068 1.924 1.188.24.12.378.1.52-.063.14-.163.606-.704.767-.945.162-.24.325-.2.548-.118.223.081 1.416.667 1.66.788.243.12.405.18.466.282.06.1.06.58-.184 1.27z"/></svg>
          Talk To Expert
        </a>
      </div>

      <!-- ٹرسٹ چیک مارکس (Trust Checks) -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-semibold text-slate-500">
        <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Permanent Links</span>
        <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real DR Verified</span>
        <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Manual Outreach</span>
        <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 98% Success Rate</span>
      </div>
    </div>
  </section>

  <!-- پبلشرز لسٹنگ بار (Editorial Logos) -->
  <section class="border-y border-slate-100 bg-slate-50/50 py-6 overflow-hidden">
    <div class="container-site">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-xs font-bold uppercase tracking-wider text-slate-400">
        <span class="flex items-center gap-2">Forbes.com <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] text-emerald-600 font-semibold">DR 95</span></span>
        <span class="flex items-center gap-2">TechCrunch.com <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] text-emerald-600 font-semibold">DR 94</span></span>
        <span class="flex items-center gap-2">BusinessInsider.com <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] text-emerald-600 font-semibold">DR 92</span></span>
        <span class="flex items-center gap-2">Entrepreneur.com <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] text-emerald-600 font-semibold">DR 90</span></span>
      </div>
    </div>
  </section>

  <!-- کاؤنٹرز (Dark Stats Section) -->
  <section class="py-16">
    <div class="container-site">
      <!-- گہرا نیلا کارڈ باکس -->
      <div class="rounded-3xl bg-slate-950 p-10 shadow-2xl shadow-blue-900/10">
        <div class="grid grid-cols-2 gap-y-10 gap-x-4 md:grid-cols-4 md:gap-y-0 text-center">
          <div>
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">100K+</p>
            <p class="mt-1 text-xs font-medium text-slate-400">Links Delivered</p>
          </div>

          <div>
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">5,000+</p>
            <p class="mt-1 text-xs font-medium text-slate-400">Active Agencies</p>
          </div>

          <div>
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">98%</p>
            <p class="mt-1 text-xs font-medium text-slate-400">Success Rate</p>
          </div>

          <div>
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600/10 text-blue-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
            </div>
            <p class="mt-4 text-3xl font-extrabold text-white">50+</p>
            <p class="mt-1 text-xs font-medium text-slate-400">Industries Served</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- سروسز اور صلاحیتیں (Services / Core Capabilities) -->
  <section class="py-16 bg-slate-50/50 border-y border-slate-100">
    <div class="container-site">
      <div class="text-center">
        <span class="section-label">Core Capabilities</span>
        <h2 class="mt-4 text-3xl font-extrabold text-slate-950">Expert SEO Frameworks</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-500">We offer specialized off-page campaigns to grow organic exposure securely.</p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          [
            {
              title: 'Authority Building',
              desc: 'High-quality guest postings, niche edits, and curated backlinks from real, vetted blogs with clean history.',
            },
            {
              title: 'Content Velocity',
              desc: 'Topic clusters, evergreen guides, and original assets structured perfectly to earn links naturally.',
            },
            {
              title: 'Technical SEO',
              desc: 'Crawl optimization, schema markup audits, and core web vitals fixes so equity distributes evenly.',
            },
          ].map((item) => (
            <div class="card p-8 group">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="mt-6 text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-500">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- قیمتوں کا ٹیبل (Pricing Section - جیسا کہ سکرین شاٹ میں ہے) -->
  <section class="py-20 bg-white">
    <div class="container-site">
      <div class="text-center">
        <span class="section-label">Pricing Plans</span>
        <h2 class="mt-4 text-3xl font-extrabold text-slate-950">Simple, Transparent Pricing</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-500">No hidden fees. No PBN footprints. Just premium links that move rankings.</p>
      </div>

      <!-- کارڈز کا گرڈ -->
      <div class="mt-14 grid gap-8 md:grid-cols-3 items-stretch">
        
        <!-- اسٹارٹر پلان -->
        <div class="card p-8 flex flex-col justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Starter</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$20</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 5 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> High-DA Sites</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Permanent Links</li>
            </ul>
          </div>
          <a href="/contact" class="btn-secondary w-full text-center mt-8 py-2.5">Get Started</a>
        </div>

        <!-- اسٹینڈرڈ پلان (Most Popular) -->
        <div class="card p-8 border-blue-200 shadow-md relative flex flex-col justify-between">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue-600 px-3.5 py-1 text-[9px] font-bold uppercase tracking-wider text-white shadow-sm">⭐ Most Popular</span>
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-blue-600 mt-2">Standard</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$70</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 15 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Managed Outreach</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Article Writing Incl.</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 24/7 Dedicated Support</li>
            </ul>
          </div>
          <a href="/contact" class="btn-primary w-full text-center mt-8 py-2.5">Buy Standard</a>
        </div>

        <!-- انٹرپرائز پلان -->
        <div class="card p-8 flex flex-col justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Enterprise</p>
            <div class="mt-4 flex items-baseline">
              <span class="text-4xl font-extrabold text-slate-950">$200</span>
              <span class="ml-1.5 text-xs text-slate-400">/ per campaign</span>
            </div>
            <ul class="mt-8 space-y-4 text-sm text-slate-600">
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> 30-45 Backlinks</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Editorial Injections</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Dedicated Strategy</li>
              <li class="flex items-center gap-2.5"><span class="text-emerald-500 font-bold">✓</span> Advanced Competitor Analysis</li>
            </ul>
          </div>
          <a href="/contact" class="btn-secondary w-full text-center mt-8 py-2.5">Contact Us</a>
        </div>

      </div>
    </div>
  </section>

  <!-- بلاگ آرٹیکلز کا سیکشن (Blog Section) -->
  <section class="py-20 bg-slate-50/30 border-t border-slate-100">
    <div class="container-site">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <span class="section-label">Insights</span>
          <h2 class="mt-4 text-2xl font-extrabold text-slate-950">From the blog</h2>
        </div>
        <a href="/blog" class="text-sm font-semibold text-blue-600 hover:text-blue-700">All articles →</a>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => <BlogCard post={post} />)}
      </div>
    </div>
  </section>

  <!-- کنورژن بینر (Footer Call to Action Banner) -->
  <section class="border-t border-slate-100 bg-white py-16">
    <div class="container-site flex flex-col items-start justify-between gap-6 rounded-3xl bg-slate-50 border border-slate-100 p-10 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-xl font-bold text-slate-950">Discuss your SEO roadmap</h2>
        <p class="mt-2 text-sm text-slate-500">A straightforward conversation. No pitch decks required.</p>
      </div>
      <a href="/contact" class="btn-primary shrink-0 w-full sm:w-auto">Get in touch</a>
    </div>
  </section>
</BaseLayout>
