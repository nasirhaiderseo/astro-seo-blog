---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Web Grouth"
  description="Web Grouth is a premium SEO and link building agency. Enterprise-grade off-page SEO, guest posting, and authority building."
>
  <section class="border-b border-slate-200 py-20 lg:py-28">
    <div class="container-site">
      <p class="section-label">SEO & Link Building</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-charcoal sm:text-5xl">
        Authority built through editorial outreach
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
        Web Grouth helps enterprise teams grow organic visibility with technical SEO,
        content velocity, and white-hat link building — executed with clarity and care.
      </p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a href="/contact" class="btn-primary">Start a project</a>
        <a href="/services" class="btn-secondary">View services</a>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-soft py-20">
    <div class="container-site">
      <p class="section-label">What we do</p>
      <h2 class="mt-3 text-2xl font-semibold text-charcoal">Core capabilities</h2>

      <div class="mt-12 grid gap-px border border-slate-200 bg-slate-200 md:grid-cols-3">
        {
          [
            {
              title: 'Technical SEO',
              desc: 'Crawlability, indexation, Core Web Vitals, and structured data — the foundation for sustainable growth.',
            },
            {
              title: 'Authority Building',
              desc: 'Guest posting, digital PR, and niche edits on editorial domains with transparent reporting.',
            },
            {
              title: 'Content Velocity',
              desc: 'Topic clusters, linkable assets, and publishing workflows that support outreach at scale.',
            },
          ].map((item) => (
            <div class="bg-white p-8">
              <h3 class="text-base font-medium text-charcoal">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 py-20">
    <div class="container-site">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
        {
          [
            { n: '500+', l: 'Publisher network' },
            { n: '2.4M', l: 'Links delivered' },
            { n: 'DR 50+', l: 'Avg. placement' },
            { n: '94%', l: 'Client retention' },
          ].map((s) => (
            <div>
              <p class="text-2xl font-semibold text-charcoal">{s.n}</p>
              <p class="mt-1 text-sm text-slate-600">{s.l}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-site">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="section-label">Writing</p>
          <h2 class="mt-3 text-2xl font-semibold text-charcoal">From the blog</h2>
        </div>
        <a href="/blog" class="text-sm text-slate-600 hover:text-charcoal">All articles</a>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => <BlogCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-soft py-16">
    <div class="container-site flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-xl font-semibold text-charcoal">Discuss your SEO roadmap</h2>
        <p class="mt-2 text-sm text-slate-600">A straightforward conversation. No pitch decks required.</p>
      </div>
      <a href="/contact" class="btn-primary shrink-0">Get in touch</a>
    </div>
  </section>
</BaseLayout>
