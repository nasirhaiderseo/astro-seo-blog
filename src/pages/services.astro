---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    id: 'technical-seo',
    title: 'Technical SEO',
    description:
      'We resolve crawl, indexation, and performance issues so link equity flows to the right pages. Technical work is the foundation — not an afterthought.',
    icon: 'technical' as const,
    features: [
      'Site crawl and indexation audits',
      'Core Web Vitals and page speed',
      'Schema and structured data',
      'Sitemaps, robots.txt, canonicals',
      'JavaScript rendering and SPA fixes',
      'International and multi-site architecture',
    ],
  },
  {
    id: 'content-velocity',
    title: 'Content Velocity',
    description:
      'Editorial production at scale. Topic clusters, linkable assets, and publishing workflows designed to support outreach and earn links naturally.',
    icon: 'content' as const,
    features: [
      'Keyword research and intent mapping',
      'Pillar pages and topic clusters',
      'Linkable assets: studies, tools, guides',
      'Editorial calendars and workflows',
      'Content refresh and decay management',
      'Human-edited production at volume',
    ],
  },
  {
    id: 'authority-building',
    title: 'Authority Building',
    description:
      'Our core off-page service. Guest posting, digital PR, niche edits, and broken link building on editorial domains with full transparency.',
    icon: 'authority' as const,
    features: [
      'Guest posting on vetted publishers',
      'Digital PR and journalist outreach',
      'Niche edits and contextual links',
      'Competitor backlink gap analysis',
      'Anchor text diversification',
      'Monthly DR, traffic, and index reports',
    ],
  },
  {
    id: 'on-page-metrics',
    title: 'On-Page Metrics',
    description:
      'On-page work aligned with off-page campaigns. Structure, internal linking, and page-level optimization so every link lands on a page built to rank.',
    icon: 'onpage' as const,
    features: [
      'Title tags and meta descriptions',
      'Heading hierarchy and semantic HTML',
      'Internal linking architecture',
      'Image and media optimization',
      'E-E-A-T and author markup',
      'Landing page conversion tuning',
    ],
  },
];

const process = [
  { step: '01', title: 'Discovery', desc: 'Audit backlinks, competitors, and content gaps.' },
  { step: '02', title: 'Strategy', desc: 'Build a 90-day roadmap with clear KPIs.' },
  { step: '03', title: 'Execution', desc: 'Ship outreach, content, and technical fixes weekly.' },
  { step: '04', title: 'Reporting', desc: 'Track rankings, DR, and referral traffic monthly.' },
];
---

<BaseLayout
  title="Services"
  description="Technical SEO, Content Velocity, Authority Building, and On-Page Metrics — Web Grouth's integrated frameworks for organic growth."
>
  <PageHero
    label="Services"
    title="Four frameworks, one disciplined process"
    description="Each service is designed to work independently or as part of a full organic growth program."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site">
      <div class="grid gap-6 lg:grid-cols-2">
        {services.map((service) => (
          <ServiceCard
            id={service.id}
            title={service.title}
            description={service.description}
            icon={service.icon}
            features={service.features}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-soft py-16">
    <div class="container-site">
      <h2 class="text-xl font-semibold text-charcoal">How we work</h2>
      <p class="mt-3 max-w-2xl text-sm text-slate-600">
        A consistent process across every engagement — clear milestones, honest reporting,
        and measurable outcomes.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          process.map((p) => (
            <div class="border border-slate-200 bg-white p-6">
              <p class="text-xs font-medium text-slate-400">{p.step}</p>
              <h3 class="mt-2 text-base font-medium text-charcoal">{p.title}</h3>
              <p class="mt-2 text-sm text-slate-600">{p.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-site">
      <div class="border border-slate-200 bg-white p-10 text-center lg:p-14">
        <h2 class="text-xl font-semibold text-charcoal">Custom pricing for your stage</h2>
        <p class="mx-auto mt-4 max-w-lg text-sm text-slate-600">
          From focused sprint packages to enterprise retainers with dedicated teams.
          We scope every project individually.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/contact" class="btn-primary">Request a quote</a>
          <a href="/blog" class="btn-secondary">Read our writing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
