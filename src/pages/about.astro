---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const milestones = [
  { year: '2018', title: 'Founded', desc: 'Launched as a boutique outreach firm for SaaS companies.' },
  { year: '2020', title: 'Publisher network', desc: 'Expanded to 200+ vetted editorial domains.' },
  { year: '2022', title: 'Enterprise tier', desc: 'Introduced dedicated account teams and formal SLAs.' },
  { year: '2026', title: 'Global reach', desc: '500+ clients across 30 countries.' },
];

const values = [
  {
    title: 'White-hat only',
    desc: 'No PBNs, no schemes. Every placement meets editorial and search quality standards.',
  },
  {
    title: 'Transparency',
    desc: 'Full reporting on URL, anchor text, domain metrics, and indexing status.',
  },
  {
    title: 'Measured outcomes',
    desc: 'We track rankings, referral traffic, and revenue — not link counts alone.',
  },
  {
    title: 'Enterprise ready',
    desc: 'NDAs, dedicated managers, and processes built for larger marketing teams.',
  },
];

const team = [
  { name: 'David Park', role: 'CEO & Founder' },
  { name: 'Sarah Mitchell', role: 'Head of Outreach' },
  { name: 'James Chen', role: 'Director of SEO' },
  { name: 'Elena Rodriguez', role: 'Content Director' },
];
---

<BaseLayout
  title="About Us"
  description="Web Grouth is an enterprise-grade SEO and link building partner. Learn about our approach, team, and standards."
>
  <PageHero
    label="About"
    title="Built for teams that take SEO seriously"
    description="We are an outreach and link building partner for companies that need scale, editorial quality, and honest reporting."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site">
      <div class="grid gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-xl font-semibold text-charcoal">Our story</h2>
          <div class="mt-6 space-y-4 text-sm leading-relaxed text-slate-600">
            <p>
              Web Grouth began in 2018 when our founders saw enterprise brands spending heavily on
              link schemes that delivered short-term gains and long-term risk. We built a different
              model — editorial outreach, vetted publishers, and reporting that marketing teams can
              actually use.
            </p>
            <p>
              Today we work with SaaS companies, e-commerce brands, and agencies that need reliable
              off-page execution. Our publisher network spans finance, technology, health, and B2B.
              Every domain is reviewed for traffic, relevance, and editorial standards.
            </p>
            <p>
              We do not sell links in bulk. We build authority through relationships, strong content,
              and disciplined process.
            </p>
          </div>
        </div>

        <div class="border border-slate-200 bg-soft p-10">
          <p class="text-4xl font-semibold text-charcoal">2.4M+</p>
          <p class="mt-2 text-sm font-medium text-charcoal">Links placed since 2018</p>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">
            Zero manual penalties across our client portfolio. Results earned through editorial
            standards, not shortcuts.
          </p>
          <div class="mt-8 border-t border-slate-200 pt-8">
            <p class="text-2xl font-semibold text-charcoal">94%</p>
            <p class="mt-1 text-sm text-slate-600">Annual client retention</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-soft py-16">
    <div class="container-site">
      <h2 class="text-xl font-semibold text-charcoal">Timeline</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          milestones.map((m) => (
            <div class="border border-slate-200 bg-white p-6">
              <p class="text-xs font-medium text-slate-500">{m.year}</p>
              <h3 class="mt-2 text-base font-medium text-charcoal">{m.title}</h3>
              <p class="mt-2 text-sm text-slate-600">{m.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-site">
      <h2 class="text-xl font-semibold text-charcoal">Principles</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          values.map((v) => (
            <div class="border border-slate-200 p-8">
              <h3 class="text-base font-medium text-charcoal">{v.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-soft py-16">
    <div class="container-site">
      <h2 class="text-xl font-semibold text-charcoal">Leadership</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          team.map((member) => (
            <div class="border border-slate-200 bg-white p-6">
              <p class="text-sm font-medium text-charcoal">{member.name}</p>
              <p class="mt-1 text-sm text-slate-600">{member.role}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-12">
        <a href="/contact" class="btn-primary">Work with us</a>
      </div>
    </div>
  </section>
</BaseLayout>
