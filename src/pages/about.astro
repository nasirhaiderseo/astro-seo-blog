---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const milestones = [
  { year: '2018', title: 'Founded', desc: 'Launched as a boutique outreach firm specializing in SaaS off-page growth.' },
  { year: '2020', title: 'Publisher Network', desc: 'Expanded to 200+ strictly vetted editorial domains with real organic traffic.' },
  { year: '2022', title: 'Full SEO Suite', desc: 'Introduced on-page metrics, content writing velocity, and technical audits.' },
  { year: '2026', title: 'Global Authority', desc: 'Proudly served 500+ happy clients across 30+ countries worldwide.' },
];

const values = [
  {
    title: 'Strict White-Hat SEO',
    desc: 'No PBNs, no spam schemes. Every single placement meets strict editorial and search engine quality standards.',
  },
  {
    title: 'Absolute Transparency',
    desc: 'Full transparent reporting on URL, anchor texts, real live traffic, and Google index status.',
  },
  {
    title: 'Revenue-Focused Outcomes',
    desc: 'We track real rankings, organic traffic spikes, and business leads — not just empty backlink numbers.',
  },
  {
    title: 'Enterprise Ready',
    desc: 'NDAs, dedicated project managers, and optimized workflows built for high-scale marketing teams.',
  },
];

const team = [
  { name: 'David Park', role: 'CEO & Founder' },
  { name: 'Sarah Mitchell', role: 'Head of Outreach' },
  { name: 'James Chen', role: 'Director of SEO' },
  { name: 'Elena Rodriguez', role: 'Content Director' },
];
---

<BaseLayout
  title="About Us — Web Grouth"
  description="Web Grouth is an enterprise-grade SEO and link building partner. Learn about our approach, team, and standards."
>
  <PageHero
    label="About Our Agency"
    title="Built for teams that take SEO and Ranking seriously"
    description="We are an authority-building partner. We help brands scale organic traffic with precise on-page, technical audits, content velocity, and high-quality guest posting."
  />

  <!-- ہماری کہانی (Our Story Section) — اینیمیٹڈ اسکرول -->
  <section class="py-16 lg:py-20 reveal">
    <div class="container-site">
      <div class="grid gap-16 lg:grid-cols-2">
        <div class="flex flex-col justify-center">
          <span class="text-xs font-bold uppercase tracking-wider text-blue-600 mb-3">Our Journey</span>
          <h2 class="text-3xl font-extrabold text-slate-950">Ranking businesses with clean SEO strategies</h2>
          <div class="mt-6 space-y-4 text-sm leading-relaxed text-slate-500">
            <p>
              ویب گروتھ (Web Grouth) کا آغاز 2018 میں اس وقت ہوا جب ہمارے بانیوں نے دیکھا کہ برانڈز ایسے لنک اسکیمز پر لاکھوں روپے ضائع کر رہے ہیں جو عارضی فائدہ اور مستقل نقصان دیتے ہیں۔ ہم نے ایک مختلف ماڈل بنایا — جہاں آن پیج (On-Page)، آف پیج (Off-Page)، ٹیکنیکل ایس ای او (Technical SEO) اور اعلیٰ درجے کے گیسٹ پوسٹس کو ملا کر سائٹس رینک کی جاتی ہیں۔
            </p>
            <p>
              آج ہم بلاگرز، ای کامرس برانڈز اور بڑی ایجنسیوں کے لیے گیسٹ پوسٹنگ اور اتھارٹی بلڈنگ کی خدمات فراہم کرتے ہیں۔ ہماری ماہر ٹیم اعلیٰ درجے کا ریسرچڈ کنٹینٹ لکھنے سے لے کر بڑے ہائی-ٹریفک بلاگز پر لنکس پلیس کرنے تک ہر کام خود سرانجام دیتی ہے۔
            </p>
            <p>
              ہم صرف لنکس نہیں بیچتے، بلکہ ہم کاروبار کو رینک کرتے ہیں، آرگینک ٹریفک بڑھاتے ہیں اور آپ کے ریونیو کو اوپر لے جاتے ہیں۔ ہمارا پبلشر نیٹ ورک فنانس، ٹیک، ہیلتھ اور بزنس جیسے بڑے شعبوں پر محیط ہے۔
            </p>
          </div>
        </div>

        <!-- دائیں طرف کا خوبصورت کاؤنٹر کارڈ -->
        <div class="rounded-3xl border border-blue-100 bg-gradient-to-br from-blue-50/20 to-transparent p-10 shadow-lg shadow-blue-50">
          <p class="text-5xl font-extrabold text-blue-600">2.4M+</p>
          <p class="mt-2 text-sm font-bold text-slate-950">Links Placed & Ranked since 2018</p>
          <p class="mt-4 text-sm leading-relaxed text-slate-500">
            ہمارے کلائنٹس کے پورٹ فولیو پر کبھی کوئی ہینڈل پینلٹی (manual penalty) نہیں آئی۔ ہم نے ہر رینکنگ اور ہر لنک پبلشرز کے ساتھ دیرپا تعلقات اور معیاری کنٹینٹ کے ذریعے حاصل کیا ہے۔
          </p>
          <div class="mt-8 border-t border-slate-100 pt-8">
            <p class="text-3xl font-extrabold text-slate-950">94%</p>
            <p class="mt-1 text-xs font-semibold text-slate-400">Annual Client Retention Rate</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ٹائم لائن (Timeline Section) — اینیمیٹڈ اسکرول -->
  <section class="border-y border-slate-100 bg-slate-50/40 py-16 reveal">
    <div class="container-site">
      <span class="section-label">Milestones</span>
      <h2 class="mt-4 text-2xl font-extrabold text-slate-950">Our Timeline</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          milestones.map((m) => (
            <div class="card p-6 hover:shadow-lg transition-all duration-300">
              <p class="text-xs font-bold text-blue-600">{m.year}</p>
              <h3 class="mt-3 text-base font-bold text-slate-950">{m.title}</h3>
              <p class="mt-2 text-xs leading-relaxed text-slate-500">{m.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- اصول اور اقدار (Principles Section) — اینیمیٹڈ اسکرول -->
  <section class="py-16 lg:py-20 reveal">
    <div class="container-site">
      <span class="section-label">Our Standards</span>
      <h2 class="mt-4 text-2xl font-extrabold text-slate-950">Core Principles</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          values.map((v) => (
            <div class="card p-8 hover:border-blue-100 transition-colors duration-300">
              <h3 class="text-base font-bold text-slate-950 flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-blue-600"></span>
                {v.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-500">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ٹیم اور لیڈرشپ (Team Section) — اینیمیٹڈ اسکرول -->
  <section class="border-t border-slate-100 bg-slate-50/40 py-16 reveal">
    <div class="container-site">
      <span class="section-label">Team Members</span>
      <h2 class="mt-4 text-2xl font-extrabold text-slate-950">Leadership Team</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          team.map((member) => (
            <div class="card p-6 hover:scale-105 transition-transform duration-300">
              <p class="text-sm font-bold text-slate-950">{member.name}</p>
              <p class="mt-1 text-xs font-medium text-blue-600">{member.role}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-12">
        <a href="/contact" class="btn-primary">Work with us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* اسکرول ریویل (Scroll Reveal) کی بنیادی حالت */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  /* جب اسکرول کر کے ایلیمنٹ ظاہر ہو */
  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // اسکرول ریویل لاجک
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('show');
      }
    });
  }, {
    threshold: 0.15 // جب ایلیمنٹ 15% اسکرین پر آئے تب اینیمیشن چلے
  });

  // تمام ریویل ایلیمنٹس کو آبزرو کرنا
  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });
</script>
