---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SocialProof from '../components/SocialProof.astro';

const contactDetails = [
  { label: 'Email Us', value: 'nasirhaiderseo@gmail.com', href: 'mailto:nasirhaiderseo@gmail.com', desc: 'Send us your project details anytime.' },
  { label: 'WhatsApp / Call', value: '+92 332 7810261', href: 'https://wa.me/923327810261', desc: 'Tap to start a quick chat with us.' },
  { label: 'Response Time', value: 'Within 24 Hours', href: null, desc: 'We reply quickly Monday to Friday.' },
];
---

<BaseLayout
  title="Contact Us — Web Grouth"
  description="Contact Web Grouth for SEO and link building services. We respond within one business day."
>
  <PageHero
    label="Get In Touch"
    title="Let's Talk About Your Google Rankings"
    description="Tell us about your website and SEO goals. We will look at your site and reply with a clear plan within 24 hours."
  />

  <section class="py-16 lg:py-20 reveal">
    <div class="container-site">
      <div class="grid gap-12 lg:grid-cols-5 items-start">
        
        <!-- بایاں کالم: رابطہ کارڈز (آسان انگلش میں) -->
        <div class="lg:col-span-2 space-y-6">
          <div>
            <span class="text-xs font-bold uppercase tracking-wider text-blue-600">Contact Info</span>
            <h2 class="text-2xl font-extrabold text-slate-950 mt-2">Direct Contact</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-500">
              Want to get high-quality guest posts, a website speed fix, or a full SEO plan? Send us a message or tap below to chat on WhatsApp.
            </p>
          </div>

          <div class="space-y-4">
            {
              contactDetails.map((item) => (
                <div class="card p-5 hover:border-blue-100 transition-colors duration-300">
                  <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">{item.label}</p>
                  <p class="text-sm font-bold text-slate-950 mt-1.5">
                    {item.href ? (
                      <a href={item.href} class="text-blue-600 hover:underline inline-flex items-center gap-1">
                        {item.value}
                      </a>
                    ) : (
                      item.value
                    )}
                  </p>
                  <p class="text-xs text-slate-400 mt-1">{item.desc}</p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- دایاں کالم: ماڈرن فارم فیلڈز -->
        <div class="lg:col-span-3">
          <form id="contact-form" class="card rounded-3xl p-8 lg:p-10 shadow-lg shadow-blue-50/50" action="#" method="POST">
            <h3 class="text-xl font-bold text-slate-950">Send a Message</h3>
            <p class="mt-1.5 text-xs text-slate-400">Fill in the fields below and we will get back to you soon.</p>

            <div class="mt-8 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-xs font-semibold text-slate-700">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your Name"
                  class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
                />
              </div>
              <div>
                <label for="email" class="mb-2 block text-xs font-semibold text-slate-700">Work Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="yourname@company.com"
                  class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
                />
              </div>
            </div>

            <div class="mt-5 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="company" class="mb-2 block text-xs font-semibold text-slate-700">Website Link / Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="example.com"
                  class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
                />
              </div>
              <div>
                <label for="budget" class="mb-2 block text-xs font-semibold text-slate-700">Monthly Budget</label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
                >
                  <option value="">Select your range</option>
                  <option value="2500-5000">$2,500 – $5,000</option>
                  <option value="5000-10000">$5,000 – $10,000</option>
                  <option value="10000-25000">$10,000 – $25,000</option>
                  <option value="25000+">$25,000+</option>
                </select>
              </div>
            </div>

            <div class="mt-5">
              <label for="service" class="mb-2 block text-xs font-semibold text-slate-700">Service You Need *</label>
              <select
                id="service"
                name="service"
                required
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
              >
                <option value="">Select a service</option>
                <option value="authority">Authority Building (Backlinks)</option>
                <option value="technical">Technical SEO & Speed</option>
                <option value="content">Content Velocity (Writing)</option>
                <option value="onpage">On-Page Metrics</option>
                <option value="full">Full SEO Retainer</option>
              </select>
            </div>

            <div class="mt-5">
              <label for="message" class="mb-2 block text-xs font-semibold text-slate-700">Project Details *</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                placeholder="Tell us about your website and what keywords you want to rank for..."
                class="w-full resize-y rounded-2xl border border-slate-200 px-4 py-3 text-sm focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary mt-6 w-full sm:w-auto py-3 px-8 shadow-lg shadow-blue-200">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ٹرسٹ اور سوشل پروف سیکشن -->
  <div class="reveal">
    <SocialProof />
  </div>
</BaseLayout>

<style>
  /* اسکرول ریویل (Scroll Reveal) کی بنیادی حالت */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  /* جب اسکرول کر کے ایلیمنٹ ظاہر ہو */
  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // فارم سبمیشن اسکرپٹ
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const original = btn.textContent;
    btn.textContent = '✓ Message Sent!';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = original;
      btn.disabled = false;
      form.reset();
    }, 3000);
  });

  // اسکرول ریویل لاجک
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('show');
      }
    });
  }, {
    threshold: 0.15
  });

  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });
</script>
