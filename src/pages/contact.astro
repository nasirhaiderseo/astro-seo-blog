---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SocialProof from '../components/SocialProof.astro';

const contactDetails = [
  {
    label: 'Email',
    value: 'hello@webgrouth.com',
    href: 'mailto:hello@webgrouth.com',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    label: 'Phone',
    value: '+1 (800) 555-1234',
    href: 'tel:+18005551234',
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  },
  {
    label: 'Office',
    value: '350 Fifth Avenue, New York, NY',
    href: null,
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    label: 'Hours',
    value: 'Mon–Fri, 9am–6pm EST',
    href: null,
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<BaseLayout
  title="Contact Us"
  description="Contact Web Grouth for premium SEO and link building services. Book a free strategy call or request a custom guest posting quote."
>
  <PageHero
    label="Contact"
    title="Let's Build Your Authority"
    description="Tell us about your goals. Our strategists respond within 24 hours with a tailored plan — no generic pitches."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Info -->
        <div class="reveal-left lg:col-span-2">
          <h2 class="text-2xl font-bold text-white">Get in Touch</h2>
          <p class="mt-4 text-slate-400 leading-relaxed">
            Whether you need a full authority building retainer or a one-time guest posting campaign,
            we're here to help. Reach out directly or fill out the form.
          </p>

          <div class="mt-8 space-y-5">
            {
              contactDetails.map((item) => (
                <div class="flex items-start gap-4">
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-500/15 text-brand-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">{item.label}</p>
                    {item.href ? (
                      <a href={item.href} class="mt-0.5 block font-medium text-white transition-colors hover:text-brand-400">
                        {item.value}
                      </a>
                    ) : (
                      <p class="mt-0.5 font-medium text-white">{item.value}</p>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="mt-10 flex gap-3">
            <a
              href="https://linkedin.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-slate-400 transition-all hover:-translate-y-0.5 hover:border-brand-500/40 hover:text-brand-400"
              aria-label="LinkedIn"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a
              href="https://twitter.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-slate-400 transition-all hover:-translate-y-0.5 hover:border-brand-500/40 hover:text-brand-400"
              aria-label="Twitter/X"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="reveal-right lg:col-span-3">
          <form
            id="contact-form"
            class="glass-card space-y-5 p-8 lg:p-10"
            action="#"
            method="POST"
          >
            <div class="mb-2">
              <h3 class="text-xl font-bold text-white">Send Us a Message</h3>
              <p class="mt-1 text-sm text-slate-400">All fields marked with * are required.</p>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-sm font-medium text-slate-300">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Jane Doe"
                  class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white placeholder:text-slate-600 transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="email" class="mb-2 block text-sm font-medium text-slate-300">Work Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@company.com"
                  class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white placeholder:text-slate-600 transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="company" class="mb-2 block text-sm font-medium text-slate-300">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="Acme Inc."
                  class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white placeholder:text-slate-600 transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="budget" class="mb-2 block text-sm font-medium text-slate-300">Monthly Budget</label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
                >
                  <option value="">Select range</option>
                  <option value="2500-5000">$2,500 – $5,000</option>
                  <option value="5000-10000">$5,000 – $10,000</option>
                  <option value="10000-25000">$10,000 – $25,000</option>
                  <option value="25000+">$25,000+</option>
                </select>
              </div>
            </div>

            <div>
              <label for="service" class="mb-2 block text-sm font-medium text-slate-300">Service Interest *</label>
              <select
                id="service"
                name="service"
                required
                class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
              >
                <option value="">Select a service</option>
                <option value="authority">Authority Building / Guest Posting</option>
                <option value="technical">Technical SEO</option>
                <option value="content">Content Velocity</option>
                <option value="onpage">On-Page Metrics</option>
                <option value="full">Full-Service Retainer</option>
              </select>
            </div>

            <div>
              <label for="message" class="mb-2 block text-sm font-medium text-slate-300">Project Details *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell us about your site, goals, and timeline..."
                class="w-full resize-y rounded-xl border border-white/10 bg-surface-900/80 px-4 py-3 text-white placeholder:text-slate-600 transition-all focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary w-full transition-transform hover:scale-[1.02]"
            >
              Send Message
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <SocialProof />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const original = btn.innerHTML;
    btn.innerHTML = '✓ Message Sent — We\'ll Reply Within 24h';
    btn.disabled = true;
    btn.classList.add('bg-brand-600');
    setTimeout(() => {
      btn.innerHTML = original;
      btn.disabled = false;
      btn.classList.remove('bg-brand-600');
      form.reset();
    }, 4000);
  });
</script>
