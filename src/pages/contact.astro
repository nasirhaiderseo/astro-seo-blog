---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SocialProof from '../components/SocialProof.astro';

const contactDetails = [
  { label: 'Email', value: 'hello@webgrouth.com', href: 'mailto:hello@webgrouth.com' },
  { label: 'Phone', value: '+1 (800) 555-1234', href: 'tel:+18005551234' },
  { label: 'Office', value: '350 Fifth Avenue, New York, NY', href: null },
  { label: 'Hours', value: 'Monday–Friday, 9am–6pm EST', href: null },
];
---

<BaseLayout
  title="Contact Us"
  description="Contact Web Grouth for SEO and link building services. We respond within one business day."
>
  <PageHero
    label="Contact"
    title="Start a conversation"
    description="Tell us about your site and goals. A strategist will respond within 24 hours."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site">
      <div class="grid gap-16 lg:grid-cols-5">
        <div class="lg:col-span-2">
          <h2 class="text-lg font-medium text-charcoal">Direct contact</h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">
            For guest posting inquiries, technical audits, or full-service retainers —
            reach out by email, phone, or the form opposite.
          </p>

          <dl class="mt-10 space-y-6">
            {
              contactDetails.map((item) => (
                <div>
                  <dt class="text-xs font-medium uppercase tracking-widest text-slate-500">
                    {item.label}
                  </dt>
                  <dd class="mt-1 text-sm text-charcoal">
                    {item.href ? (
                      <a href={item.href} class="hover:underline">
                        {item.value}
                      </a>
                    ) : (
                      item.value
                    )}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="lg:col-span-3">
          <form id="contact-form" class="border border-slate-200 bg-white p-8 lg:p-10" action="#" method="POST">
            <h3 class="text-lg font-medium text-charcoal">Send a message</h3>
            <p class="mt-1 text-sm text-slate-600">Required fields are marked with *</p>

            <div class="mt-8 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-sm text-charcoal">Full name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full border border-slate-200 px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
                />
              </div>
              <div>
                <label for="email" class="mb-2 block text-sm text-charcoal">Work email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full border border-slate-200 px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
                />
              </div>
            </div>

            <div class="mt-5 grid gap-5 sm:grid-cols-2">
              <div>
                <label for="company" class="mb-2 block text-sm text-charcoal">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full border border-slate-200 px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
                />
              </div>
              <div>
                <label for="budget" class="mb-2 block text-sm text-charcoal">Monthly budget</label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full border border-slate-200 bg-white px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
                >
                  <option value="">Select range</option>
                  <option value="2500-5000">$2,500 – $5,000</option>
                  <option value="5000-10000">$5,000 – $10,000</option>
                  <option value="10000-25000">$10,000 – $25,000</option>
                  <option value="25000+">$25,000+</option>
                </select>
              </div>
            </div>

            <div class="mt-5">
              <label for="service" class="mb-2 block text-sm text-charcoal">Service interest *</label>
              <select
                id="service"
                name="service"
                required
                class="w-full border border-slate-200 bg-white px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
              >
                <option value="">Select a service</option>
                <option value="authority">Authority Building</option>
                <option value="technical">Technical SEO</option>
                <option value="content">Content Velocity</option>
                <option value="onpage">On-Page Metrics</option>
                <option value="full">Full retainer</option>
              </select>
            </div>

            <div class="mt-5">
              <label for="message" class="mb-2 block text-sm text-charcoal">Project details *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full resize-y border border-slate-200 px-4 py-3 text-sm focus:border-charcoal focus:outline-none"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary mt-6 w-full sm:w-auto">Send message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <SocialProof />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const original = btn.textContent;
    btn.textContent = 'Message sent';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = original;
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
</script>
