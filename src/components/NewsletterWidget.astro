---
interface Props {
  compact?: boolean;
  widgetId?: string;
}

const { compact = false, widgetId = 'newsletter-sidebar' } = Astro.props;
---

<div
  class:list={[
    'relative overflow-hidden rounded-2xl border border-amber-500/30 bg-gradient-to-br from-amber-950/40 via-surface-800 to-surface-900',
    compact ? 'p-5' : 'p-6',
  ]}
  id={widgetId}
>
  <div class="absolute -left-4 top-0 h-24 w-24 rounded-full bg-amber-500/10 blur-2xl"></div>

  <div class="relative">
    <span class="mb-2 inline-flex items-center gap-1.5 rounded-full bg-amber-500/20 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-amber-300">
      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-amber-400"></span>
      Free Resource
    </span>

    <h3 class="text-base font-bold text-white">
      {compact ? 'SEO Growth Playbook' : 'Get Our Link Building Playbook'}
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-400">
      Join 12,000+ marketers. Weekly off-page SEO tactics, outreach templates, and case studies.
    </p>

    <form class="newsletter-form mt-4 space-y-3">
      <input
        type="email"
        name="email"
        required
        placeholder="you@company.com"
        class="w-full rounded-xl border border-white/10 bg-surface-900/80 px-4 py-2.5 text-sm text-white placeholder:text-slate-500 transition-all duration-300 focus:border-brand-500/50 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
      />
      <button
        type="submit"
        class="w-full rounded-xl bg-amber-500 px-4 py-2.5 text-sm font-bold text-surface-900 transition-all duration-300 hover:-translate-y-0.5 hover:bg-amber-400 hover:shadow-lg hover:shadow-amber-500/25"
      >
        Download Free Guide
      </button>
    </form>

    <p class="newsletter-success mt-3 hidden text-center text-sm font-medium text-brand-400">
      ✓ You're in! Check your inbox.
    </p>
    <p class="mt-2 text-center text-[10px] text-slate-500">No spam. Unsubscribe anytime.</p>
  </div>
</div>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const wrapper = form.closest('#newsletter-widget') ?? form.parentElement;
      const success = wrapper?.querySelector('.newsletter-success');
      const btn = form.querySelector('button[type="submit"]');

      if (btn instanceof HTMLButtonElement) {
        btn.textContent = 'Subscribed!';
        btn.disabled = true;
      }
      success?.classList.remove('hidden');
      form.querySelector('input')?.setAttribute('disabled', 'true');
    });
  });
</script>
