---
interface Props {
  title: string;
  description: string;
  icon: 'technical' | 'content' | 'authority' | 'onpage';
  features: string[];
  id?: string;
}

const { title, description, icon, features, id } = Astro.props;

const labels: Record<string, string> = {
  technical: '01',
  content: '02',
  authority: '03',
  onpage: '04',
};
---

<div id={id} class="border border-slate-200 bg-white p-8 lg:p-10">
  <span class="text-xs font-medium text-slate-400">{labels[icon]}</span>
  <h2 class="mt-3 text-xl font-semibold text-charcoal">{title}</h2>
  <p class="mt-4 text-sm leading-relaxed text-slate-600">{description}</p>

  <ul class="mt-8 space-y-3 border-t border-slate-200 pt-8">
    {
      features.map((feature) => (
        <li class="flex gap-3 text-sm text-slate-700">
          <span class="mt-0.5 text-slate-400" aria-hidden="true">—</span>
          {feature}
        </li>
      ))
    }
  </ul>
</div>
