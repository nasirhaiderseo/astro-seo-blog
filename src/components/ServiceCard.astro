---
interface Props {
  title: string;
  description: string;
  icon: 'technical' | 'content' | 'authority' | 'onpage';
  features: string[];
  id?: string;
  index?: number;
}

const { title, description, icon, features, id, index = 0 } = Astro.props;
---

<div
  id={id}
  class:list={[
    'reveal glass-card group relative overflow-hidden p-8 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-brand-500/10',
    index % 2 === 1 ? 'lg:translate-y-6' : '',
  ]}
>
  <div
    class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-brand-500/5 transition-all duration-500 group-hover:bg-brand-500/15"
  >
  </div>

  <div
    class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-700/20 text-brand-400 ring-1 ring-brand-500/30 transition-all duration-500 group-hover:scale-110 group-hover:ring-brand-400/50"
  >
    {
      icon === 'technical' && (
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
      )
    }
    {
      icon === 'content' && (
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      )
    }
    {
      icon === 'authority' && (
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      )
    }
    {
      icon === 'onpage' && (
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      )
    }
  </div>

  <h2 class="text-xl font-bold text-white transition-colors group-hover:text-brand-300">{title}</h2>
  <p class="mt-3 text-sm leading-relaxed text-slate-400">{description}</p>

  <ul class="mt-6 space-y-3 border-t border-white/5 pt-6">
    {
      features.map((feature) => (
        <li class="flex items-start gap-2.5 text-sm text-slate-300">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>
</div>
