---
interface Props {
  title: string;
  description?: string;
  label?: string;
}

const { title, description, label } = Astro.props;
---

<section class="border-b border-slate-200 bg-soft py-16 lg:py-20">
  <div class="container-site">
    {label && <p class="section-label">{label}</p>}
    <h1 class="mt-3 max-w-3xl text-3xl font-semibold tracking-tight text-charcoal sm:text-4xl">
      {title}
    </h1>
    {description && (
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-slate-600">{description}</p>
    )}
  </div>
</section>
