---
import GuestPostingCTA from './GuestPostingCTA.astro';
import LatestArticles from './LatestArticles.astro';
import NewsletterWidget from './NewsletterWidget.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPostId?: string;
}

const { posts, currentPostId } = Astro.props;
---

<aside class="space-y-6">
  <!-- 1. واٹس ایپ گیسٹ پوسٹنگ کارڈ -->
  <GuestPostingCTA />

  <!-- 2. اتھارٹی اسپرنٹ کارڈ -->
  <div class="sidebar-block border-blue-100 bg-gradient-to-br from-blue-50/10 to-transparent">
    <h3 class="text-xs font-bold uppercase tracking-wider text-blue-600">Authority Boost</h3>
    <p class="mt-2 text-sm font-extrabold text-slate-950">Full SEO Service & Strategy</p>
    <p class="mt-2 text-xs leading-relaxed text-slate-500">Get a professional technical audit, keyword mapping, and rankings plan.</p>
    <a
      href="/contact"
      class="mt-4 inline-flex items-center justify-center w-full rounded-full bg-blue-600 py-2 px-4 text-xs font-bold text-white shadow-md shadow-blue-100 hover:bg-blue-700 transition-colors"
    >
      Request Free Audit
    </a>
  </div>

  <!-- 3. حالیہ آرٹیکلز کی لسٹ -->
  <LatestArticles posts={posts} excludeId={currentPostId} />

  <!-- 4. نیوز لیٹر کارڈ -->
  <NewsletterWidget />
</aside>
