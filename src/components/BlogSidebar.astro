---
import GuestPostingCTA from './GuestPostingCTA.astro';
import LatestArticles from './LatestArticles.astro';
import NewsletterWidget from './NewsletterWidget.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPostId?: string;
}

const { posts, currentPostId } = Astro.props;
---

<aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
  <GuestPostingCTA />

  <div class="sidebar-block">
    <h3 class="text-sm font-medium text-charcoal">Authority Sprint</h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-600">
      A structured 30-day link building program with competitor analysis and monthly reporting.
    </p>
    <a
      href="/services#authority-building"
      class="mt-3 inline-block text-sm text-charcoal underline decoration-slate-300 underline-offset-4 hover:decoration-charcoal"
    >
      Learn more
    </a>
  </div>

  <LatestArticles posts={posts} excludeId={currentPostId} />
  <NewsletterWidget />
</aside>
