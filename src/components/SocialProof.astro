---
const stats = [
  { value: '500+', label: 'Clients served' },
  { value: '2.4M', label: 'Links placed' },
  { value: '94%', label: 'Retention rate' },
  { value: '4.9/5', label: 'Client rating' },
];

const testimonials = [
  {
    quote:
      'Web Grouth rebuilt our off-page program with editorial standards we could stand behind. Rankings followed within two quarters.',
    author: 'Marcus Chen',
    role: 'VP Marketing, SaaSScale',
  },
  {
    quote:
      'Clear reporting, consistent quality, and placements that actually index. The most reliable link partner we have used.',
    author: 'Elena Rodriguez',
    role: 'Head of SEO, CommerceHub',
  },
];
---

<section class="border-t border-slate-200 bg-soft py-16">
  <div class="container-site">
    <div class="grid grid-cols-2 gap-px border border-slate-200 bg-slate-200 lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="bg-white p-6 text-center">
            <p class="text-2xl font-semibold text-charcoal">{stat.value}</p>
            <p class="mt-1 text-sm text-slate-600">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        testimonials.map((t) => (
          <blockquote class="border border-slate-200 bg-white p-8">
            <p class="text-base leading-relaxed text-slate-700">"{t.quote}"</p>
            <footer class="mt-6 border-t border-slate-200 pt-4">
              <cite class="not-italic">
                <span class="text-sm font-medium text-charcoal">{t.author}</span>
                <span class="block text-sm text-slate-500">{t.role}</span>
              </cite>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
