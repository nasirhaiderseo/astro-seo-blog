---
const stats = [
  { value: '500+', label: 'Enterprise Clients' },
  { value: '2.4M', label: 'Links Placed' },
  { value: '94%', label: 'Client Retention' },
  { value: '4.9/5', label: 'Average Rating' },
];

const testimonials = [
  {
    quote:
      'Web Grouth transformed our off-page strategy. Domain Rating jumped from 32 to 58 in six months with zero penalty risk.',
    author: 'Marcus Chen',
    role: 'VP Marketing, SaaSScale',
  },
  {
    quote:
      'Their guest posting network is unmatched. Editorial quality, real traffic, and links that actually move rankings.',
    author: 'Elena Rodriguez',
    role: 'Head of SEO, CommerceHub',
  },
];
---

<section class="py-16">
  <div class="container-site">
    <div class="reveal mb-12 text-center">
      <span class="section-label">Trusted Worldwide</span>
      <h2 class="mt-4 text-3xl font-bold text-white">Results That Speak for Themselves</h2>
    </div>

    <div class="reveal grid grid-cols-2 gap-4 lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="glass-card p-6 text-center transition-all duration-500 hover:-translate-y-1">
            <p class="text-3xl font-extrabold text-gradient">{stat.value}</p>
            <p class="mt-1 text-sm text-slate-400">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        testimonials.map((t, i) => (
          <blockquote
            class:list={['reveal glass-card p-8', i === 1 ? 'lg:translate-y-4' : '']}
            style={`animation-delay: ${i * 150}ms`}
          >
            <div class="mb-4 flex gap-1 text-amber-400" aria-label="5 star rating">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-base leading-relaxed text-slate-300">"{t.quote}"</p>
            <footer class="mt-4 border-t border-white/5 pt-4">
              <cite class="not-italic">
                <span class="font-semibold text-white">{t.author}</span>
                <span class="block text-sm text-slate-500">{t.role}</span>
              </cite>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
