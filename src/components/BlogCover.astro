--- START OF FILE astro-seo-blog-main/src/components/BlogCover.astro ---
---
interface Props {
  title: string;
  image?: string;
  aspect?: 'wide' | 'card' | 'featured';
  class?: string;
}

const { title, image, aspect = 'wide', class: className = '' } = Astro.props;

const aspectClass = {
  wide: 'aspect-[21/9] rounded-2xl',
  card: 'aspect-[16/10]',
  featured: 'aspect-[4/3] rounded-2xl',
}[aspect];
---

<div class:list={['overflow-hidden border border-slate-100 bg-slate-50/50', aspectClass, className]}>
  {
    image ? (
      <img src={image} alt="" class="h-full w-full object-cover" loading="lazy" />
    ) : (
      <div class="flex h-full w-full flex-col justify-end bg-gradient-to-br from-blue-50/40 to-slate-50 p-6 sm:p-8">
        <p class="text-[10px] font-bold uppercase tracking-wider text-blue-600">Web Grouth</p>
        <p class="mt-2 text-base font-bold leading-snug text-slate-900 sm:text-lg">
          {title}
        </p>
      </div>
    )
  }
</div>
