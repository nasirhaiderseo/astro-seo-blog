---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a
  href="/"
  class:list={['inline-flex items-center gap-3', className]}
  aria-label="Web Grouth — Home"
>
  <span
    class="flex h-9 w-9 shrink-0 items-center justify-center border border-charcoal text-sm font-semibold text-charcoal"
  >
    WG
  </span>
  <span class="flex flex-col leading-tight">
    <span class="text-base font-semibold tracking-tight text-charcoal">Web Grouth</span>
    <span class="text-[11px] text-slate-500">SEO & Link Building</span>
  </span>
</a>
