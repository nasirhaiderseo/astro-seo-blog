---
import type { CollectionEntry } from 'astro:content';
import { getPostMeta } from '../lib/blog';

interface Props {
  posts: CollectionEntry<'blog'>[];
  excludeId?: string;
  limit?: number;
}

const { posts, excludeId, limit = 4 } = Astro.props;

const filtered = posts.filter((p) => p.id !== excludeId).slice(0, limit);
---

<div class="sidebar-block">
  <h3 class="text-sm font-medium text-charcoal">Recent Articles</h3>

  <ul class="mt-4 divide-y divide-slate-200">
    {
      filtered.map((post) => {
        const { title, image } = getPostMeta(post);
        return (
          <li class="py-4 first:pt-0 last:pb-0">
            <a href={`/blog/${post.id}`} class="group flex gap-3">
              <div class="h-14 w-14 shrink-0 overflow-hidden border border-slate-200 bg-soft">
                {
                  image ? (
                    <img src={image} alt="" class="h-full w-full object-cover" loading="lazy" />
                  ) : (
                    <div class="flex h-full items-center justify-center px-1">
                      <span class="text-center text-[9px] font-medium leading-tight text-slate-400">
                        {title.split(' ').slice(0, 3).join(' ')}
                      </span>
                    </div>
                  )
                }
              </div>
              <div class="min-w-0 flex-1">
                <p class="line-clamp-2 text-sm font-medium text-charcoal group-hover:underline">
                  {title}
                </p>
                <time class="mt-1 block text-xs text-slate-500">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                  })}
                </time>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>

  <a href="/blog" class="mt-4 block text-sm text-slate-600 hover:text-charcoal">
    View all articles
  </a>
</div>
