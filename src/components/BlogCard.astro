--- START OF FILE astro-seo-blog-main/src/components/BlogCard.astro ---
---
import type { CollectionEntry } from 'astro:content';
import BlogCover from './BlogCover.astro';
import { getPostMeta } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, image } = getPostMeta(post);
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card group overflow-hidden">
  <a href={`/blog/${post.id}`} class="block">
    <div class="overflow-hidden">
      <BlogCover title={title} image={image} aspect="card" class="border-none transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="p-6">
      <div class="flex items-center gap-2">
        <time datetime={pubDate.toISOString()} class="text-xs font-semibold text-slate-400">
          {formattedDate}
        </time>
      </div>
      
      <h2 class="mt-3 text-lg font-bold leading-snug text-slate-900 group-hover:text-blue-600 transition-colors">
        {title}
      </h2>
      
      <p class="mt-2.5 line-clamp-2 text-sm leading-relaxed text-slate-500">{description}</p>

      {
        tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-1.5" aria-label="Tags">
            {tags.slice(0, 2).map((tag) => (
              <li class="tag text-[10px] py-0.5 px-2.5">{tag}</li>
            ))}
          </ul>
        )
      }
    </div>
  </a>
</article>
