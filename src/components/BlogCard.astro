---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, tags, image } = post.data;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const coverImage = image ?? '/blog-placeholder.svg';
---

<article
  class:list={[
    'group glass-card overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-brand-500/10',
    featured ? 'lg:flex lg:flex-row' : '',
  ]}
>
  <a href={`/blog/${post.id}`} class:list={['block', featured ? 'lg:flex lg:w-full' : '']}>
    <div
      class:list={[
        'relative overflow-hidden bg-surface-800',
        featured ? 'lg:w-2/5 lg:shrink-0' : 'aspect-[16/10]',
      ]}
    >
      <img
        src={coverImage}
        alt=""
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
        loading="lazy"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface-900/80 via-transparent to-transparent"
      >
      </div>
    </div>

    <div class:list={['p-6', featured ? 'lg:flex lg:flex-col lg:justify-center lg:p-8' : '']}>
      <time datetime={pubDate.toISOString()} class="text-xs font-medium uppercase tracking-wider text-brand-400">
        {formattedDate}
      </time>
      <h2
        class:list={[
          'mt-2 font-bold text-white transition-colors duration-300 group-hover:text-brand-300',
          featured ? 'text-2xl lg:text-3xl' : 'text-lg',
        ]}
      >
        {title}
      </h2>
      <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-slate-400">{description}</p>

      {
        tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2" aria-label="Tags">
            {tags.slice(0, 3).map((tag) => (
              <li class="tag-pill">{tag}</li>
            ))}
          </ul>
        )
      }

      <span
        class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-400 transition-all duration-300 group-hover:gap-2"
      >
        Read article
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"
          ></path>
        </svg>
      </span>
    </div>
  </a>
</article>
