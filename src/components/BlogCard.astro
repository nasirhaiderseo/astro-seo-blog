---
import type { CollectionEntry } from 'astro:content';
import BlogCover from './BlogCover.astro';
import { getPostMeta } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, image } = getPostMeta(post);
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card group transition-colors hover:border-slate-300">
  <a href={`/blog/${post.id}`} class="block">
    <BlogCover title={title} image={image} aspect="card" />

    <div class="border-t border-slate-200 p-6">
      <time datetime={pubDate.toISOString()} class="text-xs text-slate-500">
        {formattedDate}
      </time>
      <h2 class="mt-2 text-lg font-medium text-charcoal group-hover:underline">
        {title}
      </h2>
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-600">{description}</p>

      {
        tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2" aria-label="Tags">
            {tags.slice(0, 3).map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </div>
  </a>
</article>
