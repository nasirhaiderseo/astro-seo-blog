---
import type { CollectionEntry } from 'astro:content';
import BlogCover from './BlogCover.astro';
import { getPostMeta } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, image, author } = getPostMeta(post);
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<section class="border-b border-slate-200 bg-soft py-16 lg:py-20">
  <div class="container-site">
    <p class="section-label">Latest Article</p>

    <div class="mt-10 grid items-start gap-12 lg:grid-cols-2">
      <div>
        <time datetime={pubDate.toISOString()} class="text-sm text-slate-500">
          {formattedDate}
        </time>
        <h2 class="mt-3 text-2xl font-semibold leading-tight text-charcoal sm:text-3xl lg:text-4xl">
          {title}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-slate-600">{description}</p>

        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-slate-500">
          <span>By {author}</span>
          {
            tags.slice(0, 3).map((tag) => (
              <span class="tag">{tag}</span>
            ))
          }
        </div>

        <a href={`/blog/${post.id}`} class="btn-primary mt-8 inline-flex">
          Read article
        </a>
      </div>

      <a href={`/blog/${post.id}`} class="block">
        <BlogCover title={title} image={image} aspect="featured" />
      </a>
    </div>
  </div>
</section>
