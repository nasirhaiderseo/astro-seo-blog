---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/services', label: 'Services' },
      { href: '/blog', label: 'Blog' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  {
    title: 'Services',
    links: [
      { href: '/services#technical-seo', label: 'Technical SEO' },
      { href: '/services#content-velocity', label: 'Content Velocity' },
      { href: '/services#authority-building', label: 'Authority Building' },
      { href: '/services#on-page-metrics', label: 'On-Page Metrics' },
    ],
  },
];
---

<footer class="border-t border-slate-200 bg-soft">
  <div class="container-site py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <Logo />
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-600">
          Enterprise-grade SEO and link building. White-hat outreach, transparent reporting,
          measurable results.
        </p>
      </div>

      {
        footerLinks.map((group) => (
          <div>
            <h3 class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-500">
              {group.title}
            </h3>
            <ul class="space-y-2">
              {group.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-slate-600 hover:text-charcoal">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-slate-200 pt-8 sm:flex-row sm:items-center"
    >
      <p class="text-sm text-slate-500">&copy; {year} Web Grouth</p>
      <div class="flex gap-6 text-sm text-slate-500">
        <a href="#" class="hover:text-charcoal">Privacy</a>
        <a href="#" class="hover:text-charcoal">Terms</a>
        <a href="mailto:hello@webgrouth.com" class="hover:text-charcoal">hello@webgrouth.com</a>
      </div>
    </div>
  </div>
</footer>
