---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About Us' },
      { href: '/services', label: 'Services' },
      { href: '/blog', label: 'Blog' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  {
    title: 'Services',
    links: [
      { href: '/services#technical-seo', label: 'Technical SEO' },
      { href: '/services#content-velocity', label: 'Content Velocity' },
      { href: '/services#authority-building', label: 'Authority Building' },
      { href: '/services#on-page-metrics', label: 'On-Page Metrics' },
    ],
  },
];
---

<footer class="border-t border-white/5 bg-surface-950">
  <div class="container-site py-16">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <Logo variant="footer" />
        <p class="mt-5 max-w-md text-sm leading-relaxed text-slate-400">
          Web Grouth is an enterprise-grade SEO and link building agency. We combine technical
          excellence with white-hat outreach to build authority that compounds.
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-slate-400 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-500/40 hover:text-brand-400"
            aria-label="LinkedIn"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-slate-400 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-500/40 hover:text-brand-400"
            aria-label="Twitter/X"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      {
        footerLinks.map((group) => (
          <div class="lg:col-span-3">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">{group.title}</h3>
            <ul class="space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 transition-colors duration-300 hover:text-brand-400"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="lg:col-span-1">
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">Contact</h3>
        <ul class="space-y-3 text-sm text-slate-400">
          <li>
            <a href="mailto:hello@webgrouth.com" class="transition-colors hover:text-brand-400">
              hello@webgrouth.com
            </a>
          </li>
          <li>
            <a href="tel:+18005551234" class="transition-colors hover:text-brand-400">
              +1 (800) 555-1234
            </a>
          </li>
          <li>New York · London · Remote</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 sm:flex-row"
    >
      <p class="text-sm text-slate-500">&copy; {year} Web Grouth. All rights reserved.</p>
      <div class="flex gap-6 text-sm text-slate-500">
        <a href="#" class="transition-colors hover:text-slate-300">Privacy Policy</a>
        <a href="#" class="transition-colors hover:text-slate-300">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
